{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "EventStore": {
    "DomainServices": {
      "Registrations": {
        "system|tenants|v1": {
          "AppId": "tenants",
          "MethodName": "process",
          "TenantId": "system",
          "Domain": "tenants",
          "Version": "v1"
        }
      }
    },
    "Publisher": {
      "PubSubName": "pubsub"
    },
    "RateLimiting": {
      "PermitLimit": 100,
      "WindowSeconds": 60,
      "SegmentsPerWindow": 6,
      "QueueLimit": 10
    },
    "Snapshots": {
      "DomainIntervals": {
        "tenants": 50
      }
    }
  },
  "Authentication": {
    "JwtBearer": {
      "Authority": "",
      "Audience": "hexalith-tenants",
      "Issuer": "hexalith",
      "SigningKey": "",
      "RequireHttpsMetadata": true
    }
  },
  "Tenants": {
    "BootstrapGlobalAdminUserId": ""
  }
}